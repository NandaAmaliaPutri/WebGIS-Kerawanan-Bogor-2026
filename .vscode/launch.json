{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch via Live Server",
            "url": "http://127.0.0.1:5500/webgis_kerawanan_longsor.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}